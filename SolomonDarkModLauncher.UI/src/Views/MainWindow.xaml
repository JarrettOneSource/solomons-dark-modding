<Window x:Class="SolomonDarkModLauncher.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Solomon Dark Revived"
        Width="760"
        Height="940"
        MinWidth="620"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource TitleBarBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <TextBlock Text="&#x25C6;" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="10,1,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeButton_Click" Content="&#x2500;" />
                <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeButton_Click" Content="&#x25A1;" />
                <Button Style="{StaticResource TitleBarCloseButtonStyle}" Click="CloseButton_Click" Content="&#x2715;" />
            </StackPanel>
        </Grid>

        <!-- Hero: the game's own title art -->
        <Grid Grid.Row="1" Height="180" ClipToBounds="True">
            <Image Source="/Assets/hero_sky.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Rectangle Fill="#46000000" />
            <Image Source="/Assets/moon.png"
                   Width="76"
                   Margin="0,12,64,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Opacity="0.95"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Image Source="/Assets/grass.png"
                   Height="42"
                   VerticalAlignment="Bottom"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0">
                <Image Source="/Assets/logo.png"
                       Height="116"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="R E V I V E D"
                           Margin="0,9,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{StaticResource GoldOutlineTextBrush}" />
            </StackPanel>
            <Rectangle Height="56" VerticalAlignment="Bottom">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0017151C" Offset="0" />
                        <GradientStop Color="#FF17151C" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,14,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,14"
                    Padding="14,12"
                    Background="{StaticResource ErrorBannerBackgroundBrush}"
                    BorderBrush="{StaticResource ErrorBannerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- First-run setup: hidden once a game folder is chosen -->
            <Border Grid.Row="1"
                    Margin="0,0,0,14"
                    Padding="18,14">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasGameDirectory}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock Text="Locate your game"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,5,0,0"
                                   Text="Pick your Solomon Dark 0.72.5 folder — the one containing SolomonDark.exe. The newer SB.exe remake is a different game and won't work."
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Choose Folder…"
                            Command="{Binding ChooseGameFolderCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="20,10"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="20,18"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Border Margin="0,0,0,14"
                            Padding="12,7"
                            HorizontalAlignment="Center"
                            Background="{StaticResource InputBackgroundBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSteamSession}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSteamFriendConnected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSteamFriendConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding SteamConnectionText}"
                                       FontSize="12"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSteamFriendConnected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Command="{Binding HostSteamCommand}"
                                Content="{Binding HostButtonText}"
                                MinWidth="168"
                                Margin="5,4"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Command="{Binding JoinSteamCommand}"
                                Content="Join Friend"
                                MinWidth="132"
                                Margin="5,4"
                                Style="{StaticResource OutlineButtonStyle}" />
                        <Button Command="{Binding BrowseLobbiesCommand}"
                                Content="Browse Lobbies"
                                Margin="5,4"
                                Style="{StaticResource OutlineButtonStyle}" />
                        <Button Command="{Binding LaunchSinglePlayerCommand}"
                                Content="Play Solo"
                                Margin="5,4"
                                Padding="20,10"
                                FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>

                    <TextBlock Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Joiners launch first — then the host creates the lobby and sends Steam invites."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="Lobby ID"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBox Width="210"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding LobbyId, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filled in automatically when you host. Paste one to join directly if Steam invites aren't working."
                                 Style="{StaticResource DarkTextBoxStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Lobby browser: live lobbies from the website directory -->
            <Border Grid.Row="3"
                    Margin="0,14,0,0"
                    Padding="20,16">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLobbyBrowserOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Refresh"
                                Margin="0"
                                Command="{Binding RefreshLobbiesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding LobbyBrowserSummaryText}" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="Open Lobbies" />
                    </DockPanel>

                    <ScrollViewer MaxHeight="252"
                                  Margin="0,10,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DirectoryLobbies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,9"
                                            Margin="0,0,4,2"
                                            CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource CardHoverBackgroundBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               Text="{Binding HostName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Border Margin="10,0,0,0"
                                                            Padding="7,2"
                                                            VerticalAlignment="Center"
                                                            BorderThickness="1"
                                                            CornerRadius="3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPasswordProtected}" Value="True">
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="BorderBrush" Value="{StaticResource GoldOutlineBorderBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding AccessText}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPasswordProtected}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource GoldOutlineTextBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock FontSize="12"
                                                               Foreground="{StaticResource GoldOutlineTextBrush}"
                                                               Text="{Binding BoneyardText}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="8,0,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Text="{Binding DetailText}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Margin="12,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding PlayersText}" />

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="Join"
                                                        Padding="16,7"
                                                        Command="{Binding JoinCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPasswordProtected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Join on Website"
                                                        Margin="0"
                                                        Command="{Binding OpenWebsiteCommand}"
                                                        ToolTip="Password lobbies hand out their join ticket on the website, then jump back into the loader.">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPasswordProtected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding LobbyBrowserStatusText}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LobbyBrowserStatusText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="4" Margin="0,18,0,10">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ModSummaryText}"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Button Content="Mods Folder"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenModsFolderCommand}" />
                    <Button Content="Refresh"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Margin="0" />
                </StackPanel>

                <TextBlock Text="Mods"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold" />
            </DockPanel>

            <Grid Grid.Row="5" MinHeight="160" MaxHeight="344">
                <Border Style="{StaticResource CardStyle}" />

                <ListBox ItemsSource="{Binding Mods}"
                         Margin="10,10,4,10"
                         Style="{StaticResource ModListBoxStyle}"
                         ItemContainerStyle="{StaticResource ModListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,2"
                                    Padding="14,11"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardHoverBackgroundBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Open Folder" Command="{Binding OpenFolderCommand}" />
                                        <MenuItem Header="View Manifest" Command="{Binding ViewManifestCommand}" />
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding Version}" />
                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border Padding="7,2"
                                                    Background="{Binding RuntimeChipBackground}"
                                                    CornerRadius="3">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding RuntimeChipForeground}"
                                                           Text="{Binding RuntimeChipText}" />
                                            </Border>
                                            <TextBlock Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding RequiresText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RequiresText}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              Margin="16,0,0,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsEnabled}"
                                              Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Margin="32,0"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1"
                            IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mods.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Image Source="/Assets/gravestone.png"
                           Height="76"
                           Margin="0,0,0,12"
                           Opacity="0.9"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="No mods installed"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="Drop mod folders into the mods folder, then refresh."
                               Margin="0,5,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Expander Grid.Row="6"
                      Margin="0,12,0,0"
                      Header="Advanced"
                      Style="{StaticResource AdvancedExpanderStyle}">
                <StackPanel Margin="0,8,0,0">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Instance"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   ToolTip="Separate mod setups, each with its own stage and save profile." />
                        <TextBox DockPanel.Dock="Left"
                                 Width="150"
                                 Margin="10,0,8,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding InstanceName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBoxStyle}" />
                        <Button DockPanel.Dock="Left"
                                Content="Apply"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ApplyInstanceCommand}"
                                Margin="0" />
                    </DockPanel>

                    <DockPanel Margin="0,12,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Directory"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   ToolTip="The lobby-browser server. Leave blank for the official directory." />
                        <TextBox DockPanel.Dock="Left"
                                 Width="260"
                                 Margin="10,0,0,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding DirectoryUrl, UpdateSourceTrigger=LostFocus}"
                                 Style="{StaticResource DarkTextBoxStyle}" />
                    </DockPanel>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Stage Only" Command="{Binding StageCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Open Stage Folder" Command="{Binding OpenStageFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Open Profile Folder" Command="{Binding OpenProfileFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Open Game Folder" Command="{Binding OpenGameFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Change Game Folder…" Command="{Binding ChooseGameFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                    </WrapPanel>

                    <Border Margin="0,6,0,0"
                            Padding="12,10"
                            Style="{StaticResource CardStyle}"
                            CornerRadius="8">
                        <DockPanel LastChildFill="True">
                            <CheckBox DockPanel.Dock="Right"
                                      Margin="16,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding DebugUiEnabled}"
                                      Style="{StaticResource ToggleSwitchStyle}" />

                            <StackPanel>
                                <TextBlock Text="Debug overlay"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Draws loader UI bounds in-game and keeps the Lua UI bridge active."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Workspace" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding WorkspaceRoot}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,12,0,0" Text="Game Folder" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding GameDirectorySummary}" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Command" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding CommandPreviewText, Mode=OneWay}" Style="{StaticResource CommandTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,14,0,6" Text="Log" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Height="200"
                             Text="{Binding TranscriptText, Mode=OneWay}"
                             Style="{StaticResource CommandTextBoxStyle}" />
                </StackPanel>
            </Expander>
        </Grid>
        </ScrollViewer>

        <Border Grid.Row="3" Background="{StaticResource TitleBarBackgroundBrush}" Padding="16,8" Margin="0,12,0,0">
            <TextBlock FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       Text="{Binding StatusText}" />
        </Border>
    </Grid>
</Window>
