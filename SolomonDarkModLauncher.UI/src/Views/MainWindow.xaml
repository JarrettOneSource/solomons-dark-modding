<Window x:Class="SolomonDarkModLauncher.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Solomon Dark Revived"
        Width="760"
        Height="940"
        MinWidth="560"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource TitleBarBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <TextBlock Text="&#x25C6;" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="10,1,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeButton_Click" Content="&#x2500;" />
                <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeButton_Click" Content="&#x25A1;" />
                <Button Style="{StaticResource TitleBarCloseButtonStyle}" Click="CloseButton_Click" Content="&#x2715;" />
            </StackPanel>
        </Grid>

        <!-- Hero: the game's own title art -->
        <Grid Grid.Row="1" Height="180" ClipToBounds="True">
            <Image Source="/Assets/hero_sky.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Rectangle Fill="#46000000" />
            <Image Source="/Assets/moon.png"
                   Width="76"
                   Margin="0,12,64,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Opacity="0.95"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Image Source="/Assets/grass.png"
                   Height="42"
                   VerticalAlignment="Bottom"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0">
                <Image Source="/Assets/logo.png"
                       Height="116"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="R E V I V E D"
                           Margin="0,9,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{StaticResource GoldOutlineTextBrush}" />
            </StackPanel>
            <Rectangle Height="56" VerticalAlignment="Bottom">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0017151C" Offset="0" />
                        <GradientStop Color="#FF17151C" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <ScrollViewer x:Name="MainContentScrollViewer"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,14,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,14"
                    Padding="14,12"
                    Background="{StaticResource ErrorBannerBackgroundBrush}"
                    BorderBrush="{StaticResource ErrorBannerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding ErrorMessage}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Content="Select Game Folder"
                            Command="{Binding ChooseGameFolderCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
            </Border>

            <!-- First-run setup: hidden once a game folder is chosen -->
            <Border Grid.Row="1"
                    Margin="0,0,0,14"
                    Padding="18,14">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasGameDirectory}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock Text="Select your game"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,5,0,0"
                                   Text="Select the Solomon Dark 0.72.5 folder that contains SolomonDark.exe. Do not select the newer SB.exe remake."
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Select Folder"
                            Command="{Binding ChooseGameFolderCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="20,10"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="20,18"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <UniformGrid Columns="5" Rows="1">
                        <Button Command="{Binding HostSteamCommand}"
                                Content="{Binding HostButtonText}"
                                Margin="4,4"
                                Padding="8,10"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Command="{Binding JoinSteamCommand}"
                                Content="{Binding JoinGameButtonText}"
                                Margin="4,4"
                                Padding="8,10"
                                Style="{StaticResource OutlineButtonStyle}" />
                        <Button Command="{Binding LaunchSinglePlayerCommand}"
                                Content="Play Solo"
                                Margin="4,4"
                                Padding="8,10"
                                FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding HowToPlayCommand}"
                                Content="How to Play"
                                Margin="4,4"
                                Padding="8,10"
                                Style="{StaticResource OutlineButtonStyle}" />
                        <Button Command="{Binding OpenSettingsCommand}"
                                Content="Settings"
                                Margin="4,4"
                                Padding="8,10"
                                Style="{StaticResource OutlineButtonStyle}" />
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="Lobby ID"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBox Width="210"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding LobbyId, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="The launcher adds the Lobby ID when you host. To join by ID, paste the Lobby ID here."
                                 Style="{StaticResource DarkTextBoxStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Lobby: who's in the session; boneyard + mod list fill in when the lobby shares them -->
            <Border Grid.Row="3"
                    Margin="0,14,0,0"
                    Padding="20,16">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInLobby}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding LeaveLobbyCommand}"
                                Content="Leave Lobby"
                                Margin="12,0,0,0"
                                Padding="10,4">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource OutlineButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanLeaveLobby}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock DockPanel.Dock="Right"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding LobbyIdText}" />
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding LobbyTitleText}"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>

                    <TextBlock Margin="0,5,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding LobbyConnectionDetailsText}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,14,0,2"
                               Style="{StaticResource FieldLabelStyle}"
                               Text="{Binding LobbyPlayersLabel}" />
                    <ItemsControl ItemsSource="{Binding LobbyMembers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Margin="0,0,9,0"
                                               VerticalAlignment="Center"
                                               FontSize="9"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="&#x25C6;" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Margin="10,0,0,0"
                                            Padding="8,2"
                                            VerticalAlignment="Center"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TagText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsHost}" Value="True">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource GoldOutlineBorderBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding TagText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHost}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource GoldOutlineTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LobbyBoneyardText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Margin="0,14,0,2"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="Boneyard" />
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding LobbyBoneyardText}" />
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LobbySharedMods.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Margin="0,14,0,4"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="Lobby Mods" />
                        <ItemsControl ItemsSource="{Binding LobbySharedMods}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,6"
                                            Padding="9,3"
                                            Background="{StaticResource InputBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="4" Margin="0,18,0,10">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ModSummaryText}"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Button Content="Mods Folder"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenModsFolderCommand}" />
                    <Button Content="Refresh"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Margin="0" />
                </StackPanel>

                <TextBlock Text="Mods"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold" />
            </DockPanel>

            <Grid Grid.Row="5" MinHeight="160" MaxHeight="344">
                <Border Style="{StaticResource CardStyle}" />

                <ListBox ItemsSource="{Binding Mods}"
                         Margin="10,10,4,10"
                         Style="{StaticResource ModListBoxStyle}"
                         ItemContainerStyle="{StaticResource ModListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,2"
                                    Padding="14,11"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardHoverBackgroundBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Open Folder" Command="{Binding OpenFolderCommand}" />
                                        <MenuItem Header="View Manifest" Command="{Binding ViewManifestCommand}" />
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding Version}" />
                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border Padding="7,2"
                                                    Background="{Binding RuntimeChipBackground}"
                                                    CornerRadius="3">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding RuntimeChipForeground}"
                                                           Text="{Binding RuntimeChipText}" />
                                            </Border>
                                            <TextBlock Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding RequiresText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RequiresText}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              Margin="16,0,0,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsEnabled}"
                                              Style="{StaticResource ToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Margin="32,0"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1"
                            IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mods.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Image Source="/Assets/gravestone.png"
                           Height="76"
                           Margin="0,0,0,12"
                           Opacity="0.9"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="No mods"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="Put mod folders in the Mods folder. Then, click Refresh."
                               Margin="0,5,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Expander Grid.Row="6"
                      Margin="0,12,0,0"
                      Header="Advanced"
                      Style="{StaticResource AdvancedExpanderStyle}">
                <StackPanel Margin="0,8,0,0">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Instance"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   ToolTip="Each instance has a different mod set, stage, and save profile." />
                        <TextBox DockPanel.Dock="Left"
                                 Width="150"
                                 Margin="10,0,8,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding InstanceName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBoxStyle}" />
                        <Button DockPanel.Dock="Left"
                                Content="Apply"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ApplyInstanceCommand}"
                                Margin="0" />
                    </DockPanel>

                    <DockPanel Margin="0,12,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Directory"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   ToolTip="This server lists the lobbies. Leave the field blank to use the official server." />
                        <TextBox DockPanel.Dock="Left"
                                 Width="260"
                                 Margin="10,0,0,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding DirectoryUrl, UpdateSourceTrigger=LostFocus}"
                                 Style="{StaticResource DarkTextBoxStyle}" />
                    </DockPanel>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Stage Only" Command="{Binding StageCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Open Stage Folder" Command="{Binding OpenStageFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Open Profile Folder" Command="{Binding OpenProfileFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Open Game Folder" Command="{Binding OpenGameFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="Select Game Folder" Command="{Binding ChooseGameFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                    </WrapPanel>

                    <Border Margin="0,6,0,0"
                            Padding="12,10"
                            Style="{StaticResource CardStyle}"
                            CornerRadius="8">
                        <DockPanel LastChildFill="True">
                            <CheckBox DockPanel.Dock="Right"
                                      Margin="16,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding DebugUiEnabled}"
                                      Style="{StaticResource ToggleSwitchStyle}" />

                            <StackPanel>
                                <TextBlock Text="Debug overlay"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Shows the loader UI limits in the game. It also keeps the Lua UI bridge active."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Workspace" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding WorkspaceRoot}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,12,0,0" Text="Game Folder" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding GameDirectorySummary}" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Command" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding CommandPreviewText, Mode=OneWay}" Style="{StaticResource CommandTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,14,0,6" Text="Log" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Height="200"
                             Text="{Binding TranscriptText, Mode=OneWay}"
                             Style="{StaticResource CommandTextBoxStyle}" />
                </StackPanel>
            </Expander>
        </Grid>
        </ScrollViewer>

        <Border Grid.Row="3"
                Background="{StaticResource TitleBarBackgroundBrush}"
                Padding="16,8"
                Margin="0,12,0,0">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUpdateProgressVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding UpdateStatusText}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding UpdateProgressDetailText}" />
                    </Grid>
                    <ProgressBar Grid.Row="1"
                                 AutomationProperties.Name="Update progress"
                                 Style="{StaticResource UpdateProgressBarStyle}"
                                 Value="{Binding UpdateProgressValue, Mode=OneWay}" />
                </Grid>
                <TextBlock FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="{Binding StatusText}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <!-- Host setup -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="60">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHostSetupOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Rectangle Fill="#C9000000" MouseLeftButtonDown="HostSetupScrim_MouseLeftButtonDown" />

            <Border MaxWidth="440"
                    Margin="24"
                    Padding="26,22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Host a game" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Select who can find your lobby."
                               TextWrapping="Wrap" />

                    <RadioButton Margin="0,14,0,0"
                                 GroupName="HostPrivacy"
                                 IsChecked="{Binding HostPrivacyFriends}"
                                 Style="{StaticResource HostPrivacyOptionStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Friends Only" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Only your Steam friends can find this lobby."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Margin="0,8,0,0"
                                 GroupName="HostPrivacy"
                                 IsChecked="{Binding HostPrivacyPublic}"
                                 Style="{StaticResource HostPrivacyOptionStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Public" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="All Steam players can find this lobby."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                        <TextBlock Text="Player Count"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <TextBox Width="64"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding HostPlayerCountText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="How many wizards the lobby seats. Default 4."
                                 Style="{StaticResource DarkTextBoxStyle}" />
                    </StackPanel>

                    <TextBlock Margin="0,12,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Steam starts the lobby immediately. The website shows the lobby after you go to the hub."
                               TextWrapping="Wrap" />

                    <StackPanel Margin="0,16,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Click="HostSetupCancel_Click"
                                Content="Cancel"
                                Margin="0"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Click="HostSetupCreate_Click"
                                Content="Start Lobby"
                                Margin="10,0,0,0"
                                Padding="20,9"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- How to play -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="70">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHowToPlayOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Rectangle Fill="#C9000000" MouseLeftButtonDown="HowToPlayScrim_MouseLeftButtonDown" />

            <Border MaxWidth="520"
                    Margin="24"
                    Padding="28,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="How to Play Multiplayer" />

                    <TextBlock Margin="0,16,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GoldOutlineTextBrush}"
                               Text="Host" />
                    <TextBlock Margin="0,5,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="1. Click Host Game, then choose Friends Only or Public.&#x0a;2. Pick a loadout and enter the hub.&#x0a;3. Your friends can select the lobby on the website, join through Steam, or use the Lobby ID."
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,16,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GoldOutlineTextBrush}"
                               Text="Join" />
                    <TextBlock Margin="0,5,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="1. Select the lobby on the website, join through Steam, or enter a Lobby ID and click Join Game.&#x0a;2. Confirm any host mods, then click Launch Game.&#x0a;3. Pick a loadout and enter the hub."
                               TextWrapping="Wrap" />

                    <Button Margin="0,18,0,0"
                            Padding="22,9"
                            HorizontalAlignment="Right"
                            Click="HowToPlayClose_Click"
                            Content="Close"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Launcher update consent -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="75">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLauncherUpdatePromptOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Rectangle Fill="#D9000000" />

            <Border MaxWidth="500"
                    Margin="24"
                    Padding="28,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GoldOutlineTextBrush}"
                               Text="Launcher update available" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap">
                        <Run Text="{Binding AvailableLauncherVersion, Mode=OneWay}" />
                        <Run Text=" is ready. Update now? The launcher will restart automatically." />
                    </TextBlock>

                    <StackPanel Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Content="Later"
                                Command="{Binding DismissLauncherUpdateCommand}"
                                Margin="0"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Update &amp; Restart"
                                Command="{Binding InstallLauncherUpdateCommand}"
                                Margin="10,0,0,0"
                                Padding="20,9"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Crash report consent -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="80">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCrashPromptOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Rectangle Fill="#D9000000" />

            <Border MaxWidth="520"
                    Margin="24"
                    Padding="28,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}"
                               Text="Crash detected" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding CrashReportMessage}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Nothing is sent unless you choose Submit Logs. Crash reports are stored privately and are not published with mods or profiles."
                               TextWrapping="Wrap" />

                    <Border Margin="0,14,0,0"
                            Padding="12,10"
                            Background="{StaticResource ErrorBannerBackgroundBrush}"
                            BorderBrush="{StaticResource ErrorBannerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCrashSubmissionError}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource ErrorBrush}"
                                   Text="{Binding CrashSubmissionError}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Content="Don't Send"
                                Command="{Binding DismissCrashReportCommand}"
                                Margin="0"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="{Binding CrashSubmitButtonText}"
                                Command="{Binding SubmitCrashReportCommand}"
                                Margin="10,0,0,0"
                                Padding="20,9"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Settings -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="65">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Rectangle Fill="#C9000000" MouseLeftButtonDown="SettingsScrim_MouseLeftButtonDown" />

            <Border MaxWidth="520"
                    Margin="24"
                    Padding="26,22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Settings" />

                    <TextBlock Margin="0,16,0,2"
                               Style="{StaticResource FieldLabelStyle}"
                               Text="Save" />
                    <Border Padding="14,12"
                            Background="{StaticResource InputBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <TextBlock Text="{Binding ActiveSaveName}"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding ActiveSaveStatus}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Choose Save"
                                    Command="{Binding ManageSavesCommand}"
                                    Style="{StaticResource OutlineButtonStyle}"
                                    VerticalAlignment="Center"
                                    Padding="16,8" />
                        </Grid>
                    </Border>

                    <TextBlock Margin="0,16,0,2"
                               Style="{StaticResource FieldLabelStyle}"
                               Text="Cloud Account" />
                    <Border Padding="14,12"
                            Background="{StaticResource InputBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="{Binding LinkedAccountDetailText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding CloudAccountStatus}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="{Binding AccountButtonText}"
                                        Command="{Binding OpenWebsiteAccountCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Refresh"
                                        Command="{Binding RefreshAccountCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Unlink"
                                        Command="{Binding UnlinkAccountCommand}"
                                        Margin="0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OutlineButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCloudLinked}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,16,0,2"
                               Style="{StaticResource FieldLabelStyle}"
                               Text="Diagnostics" />
                    <Border Padding="14,12"
                            Background="{StaticResource InputBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="{Binding DiagnosticsStatusText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                            <Button Content="{Binding SendLogsButtonText}"
                                    Command="{Binding SendLogsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Button Margin="0,18,0,0"
                            Padding="22,9"
                            HorizontalAlignment="Right"
                            Click="SettingsClose_Click"
                            Content="Close"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Host mod download consent -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="85">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModDownloadPromptOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Rectangle Fill="#D9000000" />

            <Border MaxWidth="480"
                    Margin="24"
                    Padding="26,22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="The host has mods" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding ModDownloadPromptText}"
                               TextWrapping="Wrap" />

                    <Border Margin="0,12,0,0"
                            Padding="12,10"
                            MaxHeight="200"
                            Background="{StaticResource InputBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ModDownloadItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Margin="0,0,8,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="9"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Text="&#x25C6;" />
                                            <TextBlock FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Downloads come from the website mod directory. Your own mod folders are not changed; the host's mod set is only used for this session."
                               TextWrapping="Wrap" />

                    <StackPanel Margin="0,16,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Content="No"
                                Command="{Binding DeclineModDownloadCommand}"
                                Margin="0"
                                MinWidth="86"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Yes"
                                Command="{Binding ConfirmModDownloadCommand}"
                                Margin="10,0,0,0"
                                MinWidth="86"
                                Padding="20,9"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
