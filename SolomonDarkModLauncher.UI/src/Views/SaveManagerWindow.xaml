<Window x:Class="SolomonDarkModLauncher.UI.Views.SaveManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saves · Solomon Dark Revived"
        Width="680"
        Height="720"
        MinWidth="560"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Right"
                    Content="{Binding AccountButtonText}"
                    Command="{Binding OpenAccountCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="10,0,0,0" />
            <StackPanel>
                <TextBlock Text="Local Saves"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="The launcher keeps these separate from the retail game."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,14"
                Padding="13,10"
                Style="{StaticResource CardStyle}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Refresh Cloud"
                        Command="{Binding RefreshCloudCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="12,0,0,0" />
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding AccountStatus}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Saves}"
                 SelectedItem="{Binding SelectedSave}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,6" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Card"
                                        Padding="14,11"
                                        Background="{StaticResource CardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Card"
                                                Property="BorderBrush"
                                                Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="Card"
                                                Property="Background"
                                                Value="{StaticResource CardHoverBackgroundBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Background="{StaticResource InputBackgroundBrush}"
                                CornerRadius="15">
                            <TextBlock Text="{Binding Number}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource GoldOutlineTextBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                            <TextBlock Margin="0,3,0,0"
                                       Text="{Binding LocalStatus}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding CloudStatus}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <Border Grid.Column="2"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                BorderBrush="{StaticResource GoldOutlineBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="ACTIVE"
                                       Foreground="{StaticResource GoldOutlineTextBrush}"
                                       FontSize="9"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="14,12"
                Background="{StaticResource ErrorBannerBackgroundBrush}"
                BorderBrush="{StaticResource ErrorBannerBorderBrush}"
                BorderThickness="1"
                CornerRadius="5">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ErrorText}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="12"
                       TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Rename"
                        Command="{Binding RenameCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" />
                <TextBox Text="{Binding SelectedName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBoxStyle}"
                         ToolTip="The selected local save name" />
            </DockPanel>
            <WrapPanel Margin="0,12,0,0">
                <Button Content="Use Selected"
                        Command="{Binding UseSelectedCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="18,9"
                        Margin="0,0,8,8" />
                <Button Content="Import Folder"
                        Command="{Binding ImportCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,8" />
                <Button Content="Restore Cloud"
                        Command="{Binding RestoreCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,8" />
                <Button Content="Open Folder"
                        Command="{Binding OpenFolderCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,8" />
                <Button Content="Close"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,0,8" />
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
